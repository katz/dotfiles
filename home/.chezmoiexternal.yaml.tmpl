{{ if and .isClient (lookPath "git") (eq (output "sh" "-c" "git ls-remote https://github.com/katz/dotfiles_claude.git HEAD >/dev/null 2>&1 && echo true || echo false" | trim) "true") -}}
".claude/rules":
  type: archive
  url: "https://github.com/katz/dotfiles_claude/releases/download/latest/rules.tar.gz"
  refreshPeriod: "168h"
  stripComponents: 1
  header:
    Authorization:
      - "Bearer {{ output "gh" "auth" "token" | trim }}"
{{ end -}}
