{{- $name := promptStringOnce . "name" "Your name" -}}
{{- $email := promptStringOnce . "email" "Your email" -}}

[data]
  name = {{ $name | quote }}
  email = {{ $email | quote }}
  isAppleSiliconMac = {{ and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") }}
  isLinux = {{ eq .chezmoi.os "linux" }}
