# ~/.zshrc

# XDG Base Directory
export XDG_CONFIG_HOME="${HOME}/.config"
export XDG_DATA_HOME="${HOME}/.local/share"
export XDG_CACHE_HOME="${HOME}/.cache"

#
# Path settings
#
typeset -gU path fpath
path=(
    $path
    /usr/local/{,s}bin(N-/)
    ${HOME}/.local/bin(N-/)
    ${HOME}/.local/bin/common(N-/)
    ${HOME}/.pulumi/bin(N-/)
)
fpath=(
    $fpath
    ${HOME}/.local/bin/common(N-/)
)

{{- if .isWSL }}
# 1Password SSH Agent bridge (WSL)
if command -v socat >/dev/null 2>&1 && command -v npiperelay.exe >/dev/null 2>&1; then
    export SSH_AUTH_SOCK="$HOME/.ssh/agent.sock"
    if ! ps -auxww | grep -q "[n]piperelay.exe -ei -s //./pipe/openssh-ssh-agent"; then
        rm -f "$SSH_AUTH_SOCK"
        (setsid socat UNIX-LISTEN:"$SSH_AUTH_SOCK",fork,mode=600 \
            EXEC:"npiperelay.exe -ei -s //./pipe/openssh-ssh-agent",nofork &) >/dev/null 2>&1
    fi
fi
{{- end }}

{{- if .isAppleSiliconMac }}
# Homebrew (Apple Silicon)
eval "$(/opt/homebrew/bin/brew shellenv)"
{{- end }}

# Cargo (Rust)
[[ -f "${HOME}/.cargo/env" ]] && . "${HOME}/.cargo/env"

# Sheldon (plugin manager)
# Handles mise activation, starship prompt, and zsh plugins
eval "$(sheldon source)"
