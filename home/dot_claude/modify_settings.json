#!/usr/bin/env bash
set -Eeuo pipefail

if [ "${DOTFILES_DEBUG:-}" ]; then
    set -x
fi

EXISTING=$(cat)

readonly BASE='{
	"$schema": "https://json.schemastore.org/claude-code-settings.json"
}'

if [ -n "$EXISTING" ]; then
    echo "$EXISTING" | jq -S --argjson base "$BASE" '$base + .'
else
    echo "$BASE" | jq -S .
fi
