#!/usr/bin/env bash
set -Eeuo pipefail

if [ "${DOTFILES_DEBUG:-}" ]; then
    set -x
fi

EXISTING=$(cat)

readonly OVERRIDE='{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"defaultMode": "auto"
	},
	"sandbox": {
		"enabled": true,
		"autoAllowBashIfSandboxed": true,
		"allowUnsandboxedCommands": true,
		"excludedCommands": [ "git", "docker" ],
		"filesystem": {
			"allowWrite": [ "//tmp" ],
			"denyRead": [ "~/.aws/credentials", "~/.ssh/", "//mnt/c/*" ]
		},
		"network": {
			"allowLocalBinding": true
		}
	},
	"skipAutoPermissionPrompt": true
}'

if [ -n "$EXISTING" ]; then
    echo "$EXISTING" | jq -S --argjson base "$OVERRIDE" '. + $base'
else
    echo "$OVERRIDE" | jq -S .
fi
