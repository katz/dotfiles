#!/usr/bin/env bash
set -Eeuo pipefail

if [ "${DOTFILES_DEBUG:-}" ]; then
    set -x
fi

EXISTING=$(cat)

readonly OVERRIDE='{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"defaultMode": "auto"
	},
	"skipAutoPermissionPrompt": true
}'

if [ -n "$EXISTING" ]; then
    echo "$EXISTING" | jq -S --argjson base "$OVERRIDE" '. + $base'
else
    echo "$OVERRIDE" | jq -S .
fi
