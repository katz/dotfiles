{{- if .isLinux }}
#!/bin/sh
set -eu

# root でない場合は sudo を使用
SUDO=""
if [ "$(id -u)" -ne 0 ]; then
  SUDO="sudo"
fi

if command -v apt-get >/dev/null 2>&1; then
  ${SUDO} apt-get update
  ${SUDO} apt-get install -y git zsh curl wget unzip
elif command -v pacman >/dev/null 2>&1; then
  ${SUDO} pacman -Syu --noconfirm git zsh curl wget unzip
fi
{{- end }}
